# Database
DATABASE_URL="postgresql://estays:estays_secret@localhost:5432/estays?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="45m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# Email (optional - logs to console in dev)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@estays.com"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# App
NODE_ENV="development"
