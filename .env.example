# Database
DATABASE_URL="postgresql://estays:estays_secret@localhost:5432/estays?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="45m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Stripe (live or test) — required on Render for card checkout
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# Public URLs (production)
WEB_URL="https://www.estayshotels.com"
API_PUBLIC_URL="https://estays-api.onrender.com"

# Razorpay (test mode — KEY_SECRET server-only, never expose to frontend)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# Email (Google Workspace — authenticate SMTP via admin@estayshotels.com)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="admin@estayshotels.com"
SMTP_PASS="your-google-app-password"

# From addresses (admin@ must have "Send mail as" for each in Google Workspace)
SMTP_FROM="E Stays Hotels <noreply@estayshotels.com>"
EMAIL_FROM="noreply@estayshotels.com"
NOREPLY_EMAIL="noreply@estayshotels.com"
WELCOME_EMAIL_FROM="E Stays Hotels <welcome@estayshotels.com>"
BOOKINGS_EMAIL_FROM="E Stays Bookings <bookings@estayshotels.com>"
BOOKINGS_BCC="bookings@estayshotels.com"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# App
NODE_ENV="development"
