# Pipeline
PIPELINE_ENV=development
DATASET_DIR=./dataset
LOG_DIR=./logs
CONFIG_DIR=./config

# Database — sqlite by default
DATABASE_URL=sqlite:///./pipeline.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/hotel_images

# HTTP / scraping (public pages only)
USER_AGENT=EStaysImageBot/1.0 (+https://www.estayshotels.com/bot)
REQUEST_TIMEOUT_SEC=30
MAX_CONCURRENT_DOWNLOADS=4
REQUESTS_PER_DOMAIN_PER_MIN=20
RESPECT_ROBOTS_TXT=true
PLAYWRIGHT_HEADLESS=true

# CLIP / ML
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=openai
CLIP_DEVICE=cpu
ENABLE_CLIP=true
ENABLE_CAPTIONING=true
MIN_CLASSIFICATION_CONFIDENCE=0.25

# API
API_HOST=0.0.0.0
API_PORT=8100
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
