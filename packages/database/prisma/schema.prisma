generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity & Access ───────────────────────────────────────────

enum RoleName {
  SUPER_ADMIN
  ADMIN
  PARTNER
  RECEPTIONIST
  GUEST
}

enum LoyaltyTier {
  SILVER
  GOLD
  VIP
  PLATINUM
}

enum PartnerStatus {
  PENDING_KYC
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum OtpPurpose {
  GUEST_REGISTER
  PARTNER_REGISTER
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  address          String?
  city             String?
  country          String?
  avatarUrl        String?
  isActive         Boolean        @default(true)
  emailVerified    Boolean        @default(false)
  loyaltyPoints    Int            @default(0)
  loyaltyTier      LoyaltyTier    @default(SILVER)
  lifetimeBookings Int            @default(0)
  partnerStatus    PartnerStatus?
  companyName      String?
  companyAddress   String?
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  bookings      Booking[]       @relation("GuestBookings")
  hotelStaff    HotelStaff[]
  notifications Notification[]
  auditLogs     AuditLog[]
  uploadedFiles FileUpload[]
  kycDocuments  PartnerKycDocument[]

  @@index([email])
  @@index([partnerStatus])
  @@map("users")
}

model EmailOtp {
  id        String     @id @default(cuid())
  email     String
  code      String
  purpose   OtpPurpose
  expiresAt DateTime
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([email, purpose])
  @@map("email_otps")
}

model PartnerKycDocument {
  id           String   @id @default(cuid())
  userId       String
  documentType String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String
  uploadedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("partner_kyc_documents")
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Hotels ────────────────────────────────────────────────────────

enum HotelStatus {
  PENDING
  APPROVED
  ACTIVE
  SUSPENDED
  REJECTED
}

enum PropertyType {
  HOTEL
  RESORT
  SERVICE_APARTMENT
  HOUSE
  VILLA
  BOUTIQUE
  HOMESTAY
}

model Hotel {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  description  String       @db.Text
  address      String
  city         String
  state        String?
  country      String
  postalCode   String?
  latitude     Float?
  longitude    Float?
  phone        String?
  email        String?
  website      String?
  googleMapsUrl String?
  googlePlaceId String?
  socialFacebook  String?
  socialInstagram String?
  socialTwitter   String?
  socialLinkedIn  String?
  socialYoutube   String?
  starRating   Int          @default(3)
  propertyType PropertyType @default(HOTEL)
  checkInTime  String       @default("15:00")
  checkOutTime String       @default("11:00")
  status       HotelStatus  @default(PENDING)
  isDemo       Boolean      @default(false)
  ownerId      String
  approvedById String?
  approvedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  roomTypes    RoomType[]
  rooms        Room[]
  ratePlans    RatePlan[]
  inventory    Inventory[]
  bookings     Booking[]
  staff        HotelStaff[]
  images       HotelImage[]
  amenities    HotelAmenity[]
  folios       Folio[]
  reviews      HotelReview[]
  complaints   HotelComplaint[]
  auditLogs    AuditLog[]
  commissionRules     CommissionRule[]
  financeSettings     PartnerFinanceSettings?
  bankAccounts        PartnerBankAccount[]
  bookingFinancials   BookingFinancial[]
  settlements         Settlement[]
  ledgerEntries       LedgerEntry[]

  @@index([city, country])
  @@index([status])
  @@index([slug])
  @@map("hotels")
}

model HotelStaff {
  id        String   @id @default(cuid())
  userId    String
  hotelId   String
  title     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelId])
  @@map("hotel_staff")
}

model Amenity {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  category  String   @default("general")
  createdAt DateTime @default(now())

  hotels HotelAmenity[]

  @@map("amenities")
}

model HotelAmenity {
  id        String @id @default(cuid())
  hotelId   String
  amenityId String

  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([hotelId, amenityId])
  @@map("hotel_amenities")
}

model HotelImage {
  id        String   @id @default(cuid())
  hotelId   String
  url       String
  caption   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("hotel_images")
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

model HotelReview {
  id           String       @id @default(cuid())
  hotelId      String
  guestName    String
  guestEmail   String?
  rating       Int
  title        String?
  comment      String       @db.Text
  status       ReviewStatus @default(PUBLISHED)
  partnerReply String?      @db.Text
  repliedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, status])
  @@map("hotel_reviews")
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintCategory {
  CLEANLINESS
  SERVICE
  BILLING
  AMENITIES
  SAFETY
  OTHER
}

model HotelComplaint {
  id          String            @id @default(cuid())
  hotelId     String
  guestName   String
  guestEmail  String?
  category    ComplaintCategory @default(OTHER)
  subject     String
  description String            @db.Text
  status      ComplaintStatus   @default(OPEN)
  resolution  String?           @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, status])
  @@map("hotel_complaints")
}

// ─── Rooms & Inventory ─────────────────────────────────────────────

model RoomType {
  id           String   @id @default(cuid())
  hotelId      String
  name         String
  description  String?  @db.Text
  maxOccupancy Int      @default(2)
  bedType      String?
  sizeSqm      Float?
  basePrice    Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rooms        Room[]
  ratePlans    RatePlan[]
  bookingRooms BookingRoom[]

  @@index([hotelId])
  @@map("room_types")
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  MAINTENANCE
  BLOCKED
}

model Room {
  id         String     @id @default(cuid())
  hotelId    String
  roomTypeId String
  roomNumber String
  floor      Int?
  status     RoomStatus @default(AVAILABLE)
  notes      String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType     RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  inventory    Inventory[]
  bookingRooms BookingRoom[]

  @@unique([hotelId, roomNumber])
  @@index([hotelId, status])
  @@map("rooms")
}

// ─── Pricing ───────────────────────────────────────────────────────

model RatePlan {
  id             String   @id @default(cuid())
  hotelId        String
  roomTypeId     String
  name           String
  description    String?
  isRefundable   Boolean  @default(true)
  cancellationHours Int   @default(24)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hotel    Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType RoomType        @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  prices   RatePlanPrice[]
  bookings Booking[]

  @@index([hotelId, roomTypeId])
  @@map("rate_plans")
}

model RatePlanPrice {
  id         String   @id @default(cuid())
  ratePlanId String
  date       DateTime @db.Date
  price      Decimal  @db.Decimal(10, 2)
  minStay    Int      @default(1)
  maxStay    Int?
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, date])
  @@index([date])
  @@map("rate_plan_prices")
}

// ─── Inventory ───────────────────────────────────────────────────────

model Inventory {
  id             String   @id @default(cuid())
  hotelId        String
  roomId         String
  date           DateTime @db.Date
  totalRooms     Int      @default(1)
  availableRooms Int      @default(1)
  bookedRooms    Int      @default(0)
  blockedRooms   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room  Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([hotelId, date])
  @@map("inventory")
}

// ─── Bookings ──────────────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  DIRECT
  OTA
  WALK_IN
  PHONE
  PARTNER_PORTAL
}

model Booking {
  id              String        @id @default(cuid())
  bookingNumber   String        @unique
  hotelId         String
  guestId         String
  ratePlanId      String?
  status          BookingStatus @default(PENDING)
  source          BookingSource @default(DIRECT)
  checkInDate     DateTime      @db.Date
  checkOutDate    DateTime      @db.Date
  adults          Int           @default(1)
  children        Int           @default(0)
  totalAmount     Decimal       @db.Decimal(10, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(10, 2)
  currency        String        @default("USD")
  specialRequests String?       @db.Text
  internalNotes   String?       @db.Text
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  hotel        Hotel          @relation(fields: [hotelId], references: [id])
  guest        User           @relation("GuestBookings", fields: [guestId], references: [id])
  ratePlan     RatePlan?      @relation(fields: [ratePlanId], references: [id])
  rooms        BookingRoom[]
  guests       BookingGuest[]
  payments     Payment[]
  folio        Folio?
  notifications Notification[]
  financial    BookingFinancial?

  @@index([hotelId, status])
  @@index([guestId])
  @@index([checkInDate, checkOutDate])
  @@index([bookingNumber])
  @@map("bookings")
}

model BookingRoom {
  id         String  @id @default(cuid())
  bookingId  String
  roomTypeId String
  roomId     String?
  nightlyRate Decimal @db.Decimal(10, 2)
  nights     Int

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])

  @@map("booking_rooms")
}

model BookingGuest {
  id          String  @id @default(cuid())
  bookingId   String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  isPrimary   Boolean @default(false)
  documentType String?
  documentNumber String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_guests")
}

// ─── PMS / Folios ──────────────────────────────────────────────────

enum FolioStatus {
  OPEN
  SETTLED
  VOID
}

model Folio {
  id        String      @id @default(cuid())
  bookingId String      @unique
  hotelId   String
  status    FolioStatus @default(OPEN)
  subtotal  Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount Decimal     @default(0) @db.Decimal(10, 2)
  total     Decimal     @default(0) @db.Decimal(10, 2)
  settledAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  booking Booking     @relation(fields: [bookingId], references: [id])
  hotel   Hotel       @relation(fields: [hotelId], references: [id])
  items   FolioItem[]

  @@map("folios")
}

enum FolioItemType {
  ROOM_CHARGE
  TAX
  SERVICE
  MINIBAR
  RESTAURANT
  LAUNDRY
  PARKING
  OTHER
  DISCOUNT
  REFUND
}

model FolioItem {
  id          String        @id @default(cuid())
  folioId     String
  type        FolioItemType
  description String
  quantity    Int           @default(1)
  unitPrice   Decimal       @db.Decimal(10, 2)
  totalPrice  Decimal       @db.Decimal(10, 2)
  date        DateTime      @default(now())
  createdBy   String?

  folio Folio @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@map("folio_items")
}

// ─── Payments ──────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  STRIPE
  UPI
  ALIPAY
  THAI_QR
  PAY_AT_HOTEL
  OTHER
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod @default(STRIPE)
  stripePaymentId String?
  stripeIntentId  String?
  description     String?
  metadata        Json?
  payerName       String?
  payerEmail      String?
  payerPhone      String?
  refundMethod    PaymentMethod?
  processedAt     DateTime?
  refundedAmount  Decimal       @default(0) @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
  financial BookingFinancial?

  @@index([bookingId])
  @@index([stripeIntentId])
  @@map("payments")
}

// ─── Finance & Settlement Engine ───────────────────────────────────

enum CommissionType {
  FLAT
  PERCENTAGE
  PROMOTIONAL
  ZERO
}

enum BookingPaymentCategory {
  PAID_ONLINE
  PAY_AT_HOTEL
}

enum FinancialSettlementStatus {
  UNSETTLED
  PENDING
  SETTLED
  REVERSED
}

enum SettlementEntryType {
  PAID_ONLINE
  PAY_AT_HOTEL
  REFUND
  MANUAL_CREDIT
  MANUAL_DEBIT
  COMMISSION
  TAX
  ADJUSTMENT
}

enum SettlementStatus {
  PENDING
  ACCEPTED
  PROCESSING
  SETTLED
  COMPLETED
  FAILED
  REVERSED
}

enum SettlementDocumentType {
  STATEMENT
  RECEIPT
  CSV
  REPORT
}

model CommissionRule {
  id               String         @id @default(cuid())
  hotelId          String?
  name             String
  type             CommissionType
  flatAmount       Decimal?       @db.Decimal(10, 2)
  percentageRate   Decimal?       @db.Decimal(7, 4)
  promotionalRate  Decimal?       @db.Decimal(7, 4)
  effectiveFrom    DateTime       @default(now())
  effectiveTo      DateTime?
  isActive         Boolean        @default(true)
  createdById      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, isActive])
  @@map("commission_rules")
}

enum SettlementPeriod {
  DAILY
  WEEKLY
}

model PartnerFinanceSettings {
  hotelId            String   @id
  autoSettleEnabled  Boolean  @default(true)
  settlementEmail    String?
  billingContactName String?
  taxRate            Decimal  @default(0) @db.Decimal(7, 4)
  taxType            String?
  taxLabel           String?
  taxCountry         String?
  openingBalance     Decimal  @default(0) @db.Decimal(12, 2)
  currency           String   @default("USD")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("partner_finance_settings")
}

model PartnerBankAccount {
  id            String   @id @default(cuid())
  hotelId       String
  partnerId     String
  bankName      String
  accountName   String
  accountNumber String
  ifscCode      String?
  swiftCode     String?
  isPrimary     Boolean  @default(false)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@map("partner_bank_accounts")
}

model BookingFinancial {
  id                 String                   @id @default(cuid())
  bookingId          String                   @unique
  hotelId            String
  guestId            String
  paymentId          String?                  @unique
  bookingNumber      String
  roomRate           Decimal                  @db.Decimal(10, 2)
  discountAmount     Decimal                  @default(0) @db.Decimal(10, 2)
  finalAmount        Decimal                  @db.Decimal(10, 2)
  paymentCategory    BookingPaymentCategory
  paymentMethod      PaymentMethod
  commissionAmount   Decimal                  @db.Decimal(10, 2)
  partnerReceivable  Decimal                  @db.Decimal(10, 2)
  platformReceivable Decimal                  @db.Decimal(10, 2)
  taxAmount          Decimal                  @default(0) @db.Decimal(10, 2)
  bookingStatus      BookingStatus
  paymentStatus      PaymentStatus
  settlementStatus   FinancialSettlementStatus @default(UNSETTLED)
  settlementId       String?
  currency           String                   @default("USD")
  completedAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  booking    Booking     @relation(fields: [bookingId], references: [id])
  hotel      Hotel       @relation(fields: [hotelId], references: [id])
  payment    Payment?    @relation(fields: [paymentId], references: [id])
  settlement Settlement? @relation(fields: [settlementId], references: [id])
  items      SettlementItem[]

  @@index([hotelId, settlementStatus])
  @@index([bookingNumber])
  @@index([settlementId])
  @@map("booking_financials")
}

model Settlement {
  id                String           @id @default(cuid())
  statementNumber   String           @unique
  hotelId           String
  partnerId         String
  settlementDate    DateTime         @db.Date
  periodStart       DateTime         @db.Date
  periodEnd         DateTime         @db.Date
  openingBalance    Decimal          @default(0) @db.Decimal(12, 2)
  paidOnlineTotal   Decimal          @default(0) @db.Decimal(12, 2)
  payAtHotelTotal   Decimal          @default(0) @db.Decimal(12, 2)
  refundsTotal      Decimal          @default(0) @db.Decimal(12, 2)
  creditsTotal      Decimal          @default(0) @db.Decimal(12, 2)
  debitsTotal       Decimal          @default(0) @db.Decimal(12, 2)
  commissionTotal   Decimal          @default(0) @db.Decimal(12, 2)
  taxTotal          Decimal          @default(0) @db.Decimal(12, 2)
  netPayable        Decimal          @default(0) @db.Decimal(12, 2)
  netReceivable     Decimal          @default(0) @db.Decimal(12, 2)
  netSettlement     Decimal          @default(0) @db.Decimal(12, 2)
  closingBalance    Decimal          @default(0) @db.Decimal(12, 2)
  bookingCount      Int              @default(0)
  periodType        SettlementPeriod @default(DAILY)
  status            SettlementStatus @default(PENDING)
  transactionRef    String?
  acceptedAt        DateTime?
  settledAt         DateTime?
  completedAt       DateTime?
  reversedAt        DateTime?
  reversalOfId      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  hotel         Hotel                  @relation(fields: [hotelId], references: [id])
  items         SettlementItem[]
  adjustments   SettlementAdjustment[]
  documents     SettlementDocument[]
  auditLogs     SettlementAuditLog[]
  journalEntries JournalEntry[]
  bookingFinancials BookingFinancial[]

  @@index([hotelId, settlementDate])
  @@index([status])
  @@index([statementNumber])
  @@map("settlements")
}

model SettlementItem {
  id                 String              @id @default(cuid())
  settlementId       String?
  hotelId            String
  bookingFinancialId String?
  entryType          SettlementEntryType
  description        String
  bookingId          String?
  paymentId          String?
  grossAmount        Decimal             @db.Decimal(12, 2)
  commission         Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal             @default(0) @db.Decimal(12, 2)
  netAmount          Decimal             @db.Decimal(12, 2)
  createdAt          DateTime            @default(now())

  settlement       Settlement?       @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  bookingFinancial BookingFinancial? @relation(fields: [bookingFinancialId], references: [id])

  @@index([settlementId])
  @@index([hotelId])
  @@map("settlement_items")
}

model SettlementAdjustment {
  id           String              @id @default(cuid())
  settlementId String?
  hotelId      String
  entryType    SettlementEntryType
  description  String
  amount       Decimal             @db.Decimal(12, 2)
  createdById  String?
  isReversal   Boolean             @default(false)
  reversesId   String?
  createdAt    DateTime            @default(now())

  settlement Settlement? @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@map("settlement_adjustments")
}

model JournalEntry {
  id           String   @id @default(cuid())
  reference    String   @unique
  description  String
  hotelId      String?
  settlementId String?
  createdById  String?
  createdAt    DateTime @default(now())

  settlement Settlement?  @relation(fields: [settlementId], references: [id])
  entries    LedgerEntry[]

  @@index([hotelId])
  @@map("journal_entries")
}

model LedgerEntry {
  id           String   @id @default(cuid())
  journalId    String?
  hotelId      String?
  bookingId    String?
  settlementId String?
  accountCode  String
  debit        Decimal  @default(0) @db.Decimal(12, 2)
  credit       Decimal  @default(0) @db.Decimal(12, 2)
  currency     String   @default("USD")
  description  String
  reference    String
  isReversal   Boolean  @default(false)
  reversesId   String?
  createdById  String?
  createdAt    DateTime @default(now())

  journal JournalEntry? @relation(fields: [journalId], references: [id])
  hotel   Hotel?        @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@index([settlementId])
  @@index([reference])
  @@map("ledger_entries")
}

model SettlementDocument {
  id           String                 @id @default(cuid())
  settlementId String
  type         SettlementDocumentType
  fileName     String
  filePath     String
  mimeType     String                 @default("text/html")
  createdAt    DateTime               @default(now())

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("settlement_documents")
}

model SettlementAuditLog {
  id           String            @id @default(cuid())
  settlementId String
  action       String
  actorId      String?
  actorEmail   String?
  ipAddress    String?
  oldStatus    SettlementStatus?
  newStatus    SettlementStatus?
  metadata     Json?
  createdAt    DateTime          @default(now())

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("settlement_audit_logs")
}

model PlatformBillingConfig {
  id                      String   @id @default("default")
  settlementNotifyEmails  String[] @default([])
  billingFromEmail        String   @default("noreply@estays.com")
  billingReplyToEmail     String?
  companyLegalName        String   @default("E Stays Hotels LLC")
  updatedAt               DateTime @updatedAt

  @@map("platform_billing_config")
}

// ─── Notifications ─────────────────────────────────────────────────

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  CHECK_IN_REMINDER
  CHECK_OUT_REMINDER
  HOTEL_APPROVED
  HOTEL_REJECTED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  bookingId String?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Files & Audit ─────────────────────────────────────────────────

model FileUpload {
  id           String   @id @default(cuid())
  uploadedById String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String
  entityType   String?
  entityId     String?
  createdAt    DateTime @default(now())

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([entityType, entityId])
  @@map("file_uploads")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  hotelId    String?
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id])
  hotel Hotel? @relation(fields: [hotelId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
